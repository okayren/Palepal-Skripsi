<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/menu_deteksi"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FCF5EE">

    <RelativeLayout
        android:id="@+id/frame_17"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:background="@drawable/navbar_border"
        android:elevation="4dp">
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_centerVertical="true"
            android:layout_marginLeft="24dp"
            android:src="@drawable/baseline_arrow_back_24" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:fontFamily="@font/playfair_display_bold"
            android:text="Deteksi Area Tubuh"
            android:textColor="#86A788"
            android:textSize="20sp" />
    </RelativeLayout>

    <TextView
        android:id="@+id/tv_judul_area"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/frame_17"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/inter_semibold"
        android:text="Kuku"
        android:textColor="#86A788"
        android:textSize="20sp" />

    <FrameLayout
        android:id="@+id/wadah_kamera"
        android:layout_width="match_parent"
        android:layout_height="340dp"
        android:layout_marginHorizontal="40dp"
        android:layout_below="@id/tv_judul_area"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_kamera_rounded"
        android:padding="10dp"
        android:clipToOutline="true">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <androidx.camera.view.PreviewView
                android:id="@+id/group_13"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </androidx.cardview.widget.CardView>

        <ImageView
            android:id="@+id/btnFlipCamera"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Tukar Kamera"
            android:elevation="4dp"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/baseline_cameraswitch_24"
            app:tint="#86A788" />
    </FrameLayout>

    <RelativeLayout
        android:id="@+id/frame_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/wadah_kamera"
        android:layout_marginHorizontal="40dp"
        android:layout_marginTop="30dp"
        android:background="@drawable/bg_panduan"
        android:padding="20dp">

        <TextView
            android:id="@+id/tv_panduan_judul"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Panduan Mengambil Gambar:"
            android:textColor="#333333"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tv_panduan_judul"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="4dp"
            android:text="• Pastikan pencahayaan cukup\n• Posisikan area dengan jelas\n• Hindari bayangan atau pantulan\n• Gunakan kamera depan bila perlu"
            android:textColor="#555555"
            android:textSize="14sp" />
    </RelativeLayout>

    <TextView
        android:id="@+id/btn_ambil_gambar_kuku"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="30dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/button_green"
        android:gravity="center"
        android:text="Ambil Gambar"
        android:textColor="#FFFECE"
        android:textSize="16sp"
        android:textStyle="bold" />

</RelativeLayout>